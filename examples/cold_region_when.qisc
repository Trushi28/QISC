proc main() gives int {
  auto total = 0;
  for int i in range(1, 10002) {
    if i < 10001 {
      total = total + 1;
    } else {
      when i {
        is 10001 {
          total = total + 5000;
        }
        else {
          total = total + 7;
        }
      }
      total = total + 3;
    }
  }
  give total;
}
