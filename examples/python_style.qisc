#pragma style:python

proc classify(int x) gives int:
    if x > 3:
        give x * 2
    else:
        give x + 1

proc sum_to(int limit) gives int:
    auto total = 0
    auto i = 0
    while i < limit:
        total = total + i
        i = i + 1
    give total

proc main() gives int:
    auto left = classify(4)
    auto right = sum_to(5)
    give left + right
